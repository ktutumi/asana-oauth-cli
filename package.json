{
  "name": "asana-oauth-cli",
  "version": "0.2.0",
  "description": "Lightweight Asana OAuth CLI for personal use",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "asn": "dist/src/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:types": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "asana",
    "oauth",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
